-- Test OpenMetrics endpoint.
-- This test verifies the /metrics endpoint returns Prometheus-formatted metrics.
SET client_min_messages TO warning;
-- Setup test table.
DROP TABLE IF EXISTS metrics_test CASCADE;
CREATE TABLE metrics_test AS
SELECT i, i * 2 as val
FROM generate_series(1, 10000) i;
ANALYZE metrics_test;
-- Run a query that will generate metrics.
SELECT COUNT(*) FROM metrics_test WHERE val > 5000;
 count 
-------
  7500
(1 row)

-- Give the extension time to process.
SELECT pg_sleep(0.1);
 pg_sleep 
----------
 
(1 row)

-- Query the /metrics endpoint using curl.
-- This assumes the default listen address of 127.0.0.1:9187.
\! curl -s http://127.0.0.1:9187/metrics | head -30
# HELP pg_what_is_happening_active_query_node_rows Rows produced by active query plan node
# TYPE pg_what_is_happening_active_query_node_rows gauge
# HELP pg_what_is_happening_active_query_node_time_seconds Execution time for active query plan node
# TYPE pg_what_is_happening_active_query_node_time_seconds gauge
# HELP pg_what_is_happening_active_query_node_time_percent Percentage of total query time spent in this node
# TYPE pg_what_is_happening_active_query_node_time_percent gauge
# HELP pg_what_is_happening_active_query_node_cache_hits Shared buffer cache hits
# TYPE pg_what_is_happening_active_query_node_cache_hits gauge
# HELP pg_what_is_happening_active_query_node_cache_misses Shared buffer cache misses
# TYPE pg_what_is_happening_active_query_node_cache_misses gauge
# HELP pg_what_is_happening_active_query_node_local_cache_hits Local buffer cache hits
# TYPE pg_what_is_happening_active_query_node_local_cache_hits gauge
# HELP pg_what_is_happening_active_query_node_local_cache_misses Local buffer cache misses
# TYPE pg_what_is_happening_active_query_node_local_cache_misses gauge
# HELP pg_what_is_happening_active_query_node_spill_file_reads Blocks read from spill files
# TYPE pg_what_is_happening_active_query_node_spill_file_reads gauge
# HELP pg_what_is_happening_active_query_node_spill_file_writes Blocks written to spill files
# TYPE pg_what_is_happening_active_query_node_spill_file_writes gauge
-- Verify endpoint is responding.
\! curl -s -o /dev/null -w "HTTP Status: %{http_code}\n" http://127.0.0.1:9187/metrics
HTTP Status: 200
-- Check for expected metric names in output.
\! curl -s http://127.0.0.1:9187/metrics | grep -c "pg_what_is_happening_active_query_node"
18
-- Check for specific metrics we expect.
\! curl -s http://127.0.0.1:9187/metrics | grep -E "^# (HELP|TYPE) pg_what_is_happening" | head -10
# HELP pg_what_is_happening_active_query_node_rows Rows produced by active query plan node
# TYPE pg_what_is_happening_active_query_node_rows gauge
# HELP pg_what_is_happening_active_query_node_time_seconds Execution time for active query plan node
# TYPE pg_what_is_happening_active_query_node_time_seconds gauge
# HELP pg_what_is_happening_active_query_node_time_percent Percentage of total query time spent in this node
# TYPE pg_what_is_happening_active_query_node_time_percent gauge
# HELP pg_what_is_happening_active_query_node_cache_hits Shared buffer cache hits
# TYPE pg_what_is_happening_active_query_node_cache_hits gauge
# HELP pg_what_is_happening_active_query_node_cache_misses Shared buffer cache misses
# TYPE pg_what_is_happening_active_query_node_cache_misses gauge
-- Cleanup.
DROP TABLE metrics_test;
