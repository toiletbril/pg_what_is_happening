SELECT
  COUNT(*) = COUNT(DISTINCT backend_pid || '-' || query_id || '-' || node_id) AS no_duplicate_nodes
FROM what_is_happening.v1_status
WHERE query_text LIKE '%pg_sleep(0.0%';
